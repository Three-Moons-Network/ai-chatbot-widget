# AI Chatbot Widget — Example Configuration

aws_region = "us-east-1"
aws_profile = "default"

project_name = "ai-chatbot-widget"
environment  = "dev"

# Anthropic API key (required)
# Get from https://console.anthropic.com
anthropic_api_key = "sk-ant-..."

anthropic_model = "claude-sonnet-4-20250514"
max_tokens      = 1024

# Lambda configuration
lambda_memory = 256
lambda_timeout = 30

# Conversation session TTL (hours)
# Default: 168 (7 days)
# Conversations older than this will be automatically deleted by DynamoDB TTL
conversation_ttl_hours = 168

# CloudWatch log retention (days)
log_retention_days = 14

# DynamoDB billing mode: PAY_PER_REQUEST or PROVISIONED
dynamodb_billing_mode = "PAY_PER_REQUEST"

# API Gateway throttling
# For production, adjust these based on expected load
api_throttle_rate_limit  = 100  # Requests per second
api_throttle_burst_limit = 200  # Burst capacity
